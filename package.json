{
  "name": "mcp-debugger",
  "displayName": "MCP Debugger",
  "description": "Real-time debugging and monitoring for MCP (Model Context Protocol) Servers",
  "version": "0.0.1",
  "publisher": "mcp-debugger",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "mcp",
    "debugger",
    "monitoring",
    "model context protocol"
  ],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourname/mcp-debugger"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:mcpDebugger.openDashboard",
    "onCommand:mcpDebugger.refreshServers",
    "onView:mcpDebugger.servers"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mcpDebugger.openDashboard",
        "title": "MCP Debugger: Open Dashboard",
        "category": "MCP Debugger"
      },
      {
        "command": "mcpDebugger.refreshServers",
        "title": "MCP Debugger: Refresh Servers",
        "category": "MCP Debugger",
        "icon": "$(refresh)"
      },
      {
        "command": "mcpDebugger.selectHost",
        "title": "MCP Debugger: Select Host",
        "category": "MCP Debugger"
      },
      {
        "command": "mcpDebugger.toggleMonitoring",
        "title": "MCP Debugger: Toggle Monitoring",
        "category": "MCP Debugger"
      },
      {
        "command": "mcpDebugger.clearLogs",
        "title": "MCP Debugger: Clear Logs",
        "category": "MCP Debugger"
      },
      {
        "command": "mcpDebugger.callTestTool",
        "title": "MCP Debugger: Call Test Tool",
        "category": "MCP Debugger"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcpDebugger",
          "title": "MCP Debugger",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "mcpDebugger": [
        {
          "id": "mcpDebugger.servers",
          "name": "Servers"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "mcpDebugger.refreshServers",
          "when": "view == mcpDebugger.servers",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:wrapper && npm run build:webview",
    "build:extension": "webpack --config webpack.config.js --mode production",
    "build:wrapper": "webpack --config webpack.wrapper.config.js --mode production",
    "build:webview": "webpack --config webpack.webview.config.js --mode production",
    "watch": "npm run watch:extension & npm run watch:wrapper & npm run watch:webview",
    "watch:extension": "webpack --config webpack.config.js --mode development --watch",
    "watch:wrapper": "webpack --config webpack.wrapper.config.js --mode development --watch",
    "watch:webview": "webpack --config webpack.webview.config.js --mode development --watch",
    "compile": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test:unit": "jest --config jest.config.js",
    "test": "npm run test:unit",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^2.31.1",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.1.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.3",
    "webpack": "^5.92.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1"
  }
}
